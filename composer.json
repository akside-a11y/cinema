{
    "name": "cinesync/watchparty",
    "description": "Real-time watch party with WebSocket sync",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "cboden/ratchet": "^0.4.4",
        "react/event-loop": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "CineSync\\": "src/"
        }
    },
    "scripts": {
        "start": "php server.php 8080",
        "start-dev": "php -S localhost:3000 -t . & php server.php 8080"
    }
}
